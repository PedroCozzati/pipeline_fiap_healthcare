# Copie para .env e ajuste os valores:
#   cp .env.example .env
#
# Ou gere automaticamente após o Terraform:
#   .\scripts\generate-env.ps1   (Windows)
#   ./scripts/generate-env.sh    (Linux/macOS)

# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=seu-projeto-gcp
GCP_REGION=us-central1

# Caminho local da service account (fora do Docker)
GOOGLE_APPLICATION_CREDENTIALS=credentials/gcp-sa.json

# Caminho no host para bind mount no Docker (precisa de ./ ou caminho absoluto)
GCP_SA_KEY_FILE=./credentials/gcp-sa.json

# ── Cloud Storage ─────────────────────────────────────────────────────────────
GCS_BUCKET_NAME=seu-projeto-trajeto-data
GCS_ARTIFACTS_PREFIX=model_evasao/v1/

# ── Cloud SQL (PostgreSQL) ────────────────────────────────────────────────────
CLOUD_SQL_INSTANCE_CONNECTION_NAME=seu-projeto-gcp:us-central1:trajeto-db-dev
CLOUD_SQL_DATABASE=trajeto_saude
CLOUD_SQL_USER=app_user
CLOUD_SQL_PASSWORD=altere-esta-senha

# Alternativa local com Cloud SQL Auth Proxy (opcional):
# CLOUD_SQL_HOST=127.0.0.1
# CLOUD_SQL_PORT=5432

# ── Microserviços (URLs internas Docker) ─────────────────────────────────────
STORAGE_SERVICE_URL=http://storage:8001
PREDICTION_SERVICE_URL=http://prediction:8002

# Diretório do pipeline dentro de TrajetoSaude (raw/ + output/)
PIPELINE_BASE_DIR=data

# ── Modelo de predição ────────────────────────────────────────────────────────
# local = joblib em disco | gcs = artefato no bucket | vertex = Reasoning Engine
MODEL_SOURCE=local
MODEL_GCS_URI=gs://seu-projeto-trajeto-data/model_evasao/v1/risk_model.joblib
MODEL_LOCAL_PATH=artefatos/risk_model.joblib

# ── Vertex AI — Agent Engine / Reasoning Engines (chat Sentinel.AI) ────────────
# Gerados automaticamente pelo Terraform (infra/agent_engine.tf) — copie os
# valores de `terraform output agent_engine_query_urls` após o apply, ou deixe
# em branco para usar os agentes hardcoded em sentinel_ai/app/config.py.
GCP_REASONING_ENGINE_URL=
GCP_REASONING_ENGINE_AGENTE_URL=
GCP_REASONING_ENGINE_UBS_PER_3KM_URL=

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=altere-esta-chave-em-producao

# Token da API InfoSimples para validação COREN (opcional)
INFOSIMPLES_TOKEN=

# ── Gateway ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:4200"]
