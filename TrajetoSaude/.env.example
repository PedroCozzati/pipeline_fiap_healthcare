# Copie para .env e ajuste os valores
# cp .env.example .env

# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=traj-saude
GCP_REGION=us-west1

# Caminho local da service account (montado no container como /secrets/gcp-sa.json)
GOOGLE_APPLICATION_CREDENTIALS=credentials/gcp-sa.json

# ── Cloud Storage ─────────────────────────────────────────────────────────────
GCS_BUCKET_NAME=traj-saude-us
GCS_ARTIFACTS_PREFIX=model_evasao/v1/

# ── Cloud SQL (PostgreSQL) ────────────────────────────────────────────────────
CLOUD_SQL_INSTANCE_CONNECTION_NAME=traj-saude:us-west1:trajeto-db
CLOUD_SQL_DATABASE=trajeto_saude
CLOUD_SQL_USER=app_user
CLOUD_SQL_PASSWORD=changeme

# Para desenvolvimento local sem Cloud SQL Proxy, use host direto:
# CLOUD_SQL_HOST=127.0.0.1
# CLOUD_SQL_PORT=5432

# ── Modelo de predição ────────────────────────────────────────────────────────
# local = joblib em disco | gcs = artefato no bucket | vertex = Reasoning Engine
MODEL_SOURCE=local
MODEL_GCS_URI=gs://trajeto-saude-data/artefatos/risk_model.joblib
MODEL_LOCAL_PATH=artefatos/risk_model.joblib

GCP_REASONING_ENGINE_URL=https://us-west1-aiplatform.googleapis.com/v1/projects/traj-saude/locations/us-west1/reasoningEngines/4633016544006242304:query

# ── Gateway ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:4200"]
